# ===========================================
# OfCoach — Variables d'environnement
# ===========================================
# Copier ce fichier en .env (ou .env.local) et remplir les valeurs.
# Ne jamais commiter .env (il doit être dans .gitignore).

# --- Obligatoire pour l'app (front Supabase) ---
# URL du projet Supabase (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Clé anonyme (publique) Supabase (Dashboard → Settings → API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Optionnel (serveur / AI Studio) ---
# GEMINI_API_KEY="..."   # Si utilisation de l'API Gemini côté serveur
# APP_URL="..."          # URL de l'app pour OAuth / callbacks
